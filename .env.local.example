# Where the hourly API runs. Local dev defaults to Fastify on :4100.
# Production: https://api-hourly.sinaitaxi.com.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

# Stripe publishable key — safe to ship to the client. pk_test_ in
# dev, pk_live_ in production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Maps Platform key for the storefront pickup autocomplete
# + static map preview. Restrict this key to HTTP referrers (your
# domains) and to the Places + Geocoding + Maps Static APIs in
# the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
